const express = require('express');
const router = express.Router();

const db = require('../db');
const authenticate = require('../middleware/auth');
const authorize = require('../middleware/authorize');


// Manager/Admin can set prices
router.put('/:id/price',
  authenticate,
  authorize('set_prices'),
  async (req, res) => {
    const { price } = req.body;

    await db.query(
      "UPDATE inventory SET price=? WHERE item_id=?",
      [price, req.params.id]
    );

    res.json({ message: "Price updated" });
});


// Employee can update inventory
router.put('/:id/quantity',
  authenticate,
  authorize('update_inventory'),
  async (req, res) => {
    const { quantity } = req.body;

    await db.query(
      "UPDATE inventory SET quantity=? WHERE item_id=?",
      [quantity, req.params.id]
    );

    res.json({ message: "Inventory updated" });
});

module.exports = router;